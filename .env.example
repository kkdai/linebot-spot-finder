# LINE Bot
ChannelSecret=your_channel_secret_here
ChannelAccessToken=your_channel_access_token_here

# Google Cloud / Vertex AI (REQUIRED for Maps Grounding and Gemini)
GOOGLE_CLOUD_PROJECT=your-gcp-project-id
GOOGLE_CLOUD_LOCATION=us-central1

# Google Maps Platform (REQUIRED for Places API integration)
GOOGLE_MAPS_API_KEY=your-google-maps-api-key

# Optional model overrides
CHAT_MODEL=gemini-2.5-flash
SESSION_TIMEOUT_MINUTES=30
MAX_HISTORY_LENGTH=20
